# StudyGenie AI - Environment Configuration Example
# Copy this file to '.env' and insert your actual keys before building/running.

# Gemini API Key (Required for AI chat, smart tips, and automatic textbook card generation)
# Obtain your key from the Google AI Studio console: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional Server Port (Defaults to 3000 if not specified)
PORT=3000
